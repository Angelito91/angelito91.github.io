---
import { getLangFromUrl, useTranslations } from "@/i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

interface Props {
    variant?: "desktop" | "mobile" | "about";
}

const { variant = "desktop" } = Astro.props;

const cvLink = lang === "es" ? t("cv.es") : t("cv.en");

const buttonClasses = {
    desktop:
        "hidden md:inline-flex items-center gap-2 px-5 py-2.5 text-[0.8125rem] font-semibold rounded-full bg-[hsl(var(--color-primary)/0.12)] text-[hsl(var(--color-primary))] border border-[hsl(var(--color-primary)/0.2)] hover:bg-[hsl(var(--color-primary)/0.2)] hover:border-[hsl(var(--color-primary)/0.35)] transition-all duration-300",
    mobile: "inline-flex items-center gap-2 px-4 py-2 text-xs font-semibold rounded-full bg-[hsl(var(--color-primary)/0.12)] text-[hsl(var(--color-primary))] border border-[hsl(var(--color-primary)/0.2)]",
    about: "inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-[hsl(258_85%_68%)] text-[hsl(225_10%_3%)] font-semibold hover:bg-[hsl(258_85%_73%)] transition-colors duration-300",
};
---

<a
    href={cvLink}
    target="_blank"
    rel="noopener noreferrer"
    class:list={[
        "inline-flex items-center gap-2",
        {
            [buttonClasses.desktop]: variant === "desktop",
            [buttonClasses.mobile]: variant === "mobile",
            [buttonClasses.about]: variant === "about",
        },
    ]}
>
    <svg
        class="w-3.5 h-3.5"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
    >
        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
        <polyline points="7 10 12 15 17 10"></polyline>
        <line x1="12" y1="15" x2="12" y2="3"></line>
    </svg>
    <span>{t("nav.resume")}</span>
</a>
