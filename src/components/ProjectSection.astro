---
import { getLangFromUrl, useTranslations } from "@/i18n/utils";
import type { Language } from "@/i18n/translations";
import projectsData from "@/data/projects.json";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

interface ProjectLink {
    github: string | null;
    demo: string | null;
}

interface ProjectData {
    id: string;
    title: Record<string, string>;
    description: Record<string, string>;
    image: string;
    tech: string[];
    category: string;
    featured: boolean;
    links: ProjectLink;
    year: number;
}

const projects = projectsData as ProjectData[];

const categories = [
    { key: "all", label: t("projects.filter.all") },
    { key: "web", label: t("projects.filter.web") },
    { key: "game", label: t("projects.filter.game") },
    { key: "tool", label: t("projects.filter.tool") },
];

// Color mapping for tech tags
const techColors: Record<string, string> = {
    "Unreal Engine 5": "0 72% 56%",
    "Godot Engine": "168 70% 52%",
    Blueprint: "0 72% 56%",
    GDScript: "168 70% 52%",
    "3D Graphics": "35 90% 62%",
    Physics: "258 85% 68%",
    "Ray Tracing": "0 72% 56%",
    "Level Design": "205 85% 60%",
    "Game AI": "258 85% 68%",
    "Asset Management": "340 75% 62%",
    "2D/3D Hybrid": "35 90% 62%",
    "Puzzle Design": "258 85% 68%",
    "Interactive Storytelling": "340 75% 62%",
    "Physics Simulation": "258 85% 68%",
    "Educational Design": "205 85% 60%",
    "Interactive UI": "35 90% 62%",
    "Data Visualization": "205 85% 60%",
    "Web Export": "205 85% 60%",
    "Educational Tools": "258 85% 68%",
    "Quest System": "168 70% 52%",
    "Inventory Management": "340 75% 62%",
    "Audio Design": "258 85% 68%",
    "AI Systems": "35 90% 62%",
    "Game Design": "340 75% 62%",
    "Game Optimization": "0 72% 56%",
    "Particle Systems": "258 85% 68%",
    "C++": "168 70% 52%",
    OpenGL: "258 85% 68%",
    ImGui: "258 85% 68%",
    CMake: "258 85% 68%",
    React: "205 85% 60%",
    "Node.js": "168 70% 52%",
    "Express.js": "168 70% 52%",
    PostgreSQL: "205 85% 60%",
    "D3.js": "35 90% 62%",
    "Godot 4": "35 90% 62%",
    GDScript: "35 90% 62%",
    Blender: "35 90% 62%",
    GLSL: "258 85% 68%",
    "Vue.js": "168 70% 52%",
    Express: "168 70% 52%",
    "Socket.io": "340 75% 62%",
    MongoDB: "168 70% 52%",
    TypeScript: "205 85% 60%",
    "Canvas API": "258 85% 68%",
    "Tailwind CSS": "205 85% 60%",
    Rust: "35 90% 62%",
    TOML: "35 90% 62%",
    Shell: "168 70% 52%",
    "GitHub Actions": "258 85% 68%",
    Python: "35 90% 62%",
    FastAPI: "168 70% 52%",
    Stripe: "258 85% 68%",
    Docker: "35 90% 62%",
    Linux: "258 85% 68%",
    Supabase: "340 75% 62%",
    DSA: "258 85% 68%",
    Algorithms: "168 70% 52%",
    "Compiler Design": "35 90% 62%",
    Parser: "258 85% 68%",
    AST: "258 85% 68%",
    "Type Checking": "340 75% 62%",
    Async: "168 70% 52%",
    "Async Programming": "168 70% 52%",
    "API Integration": "205 85% 60%",
    Caching: "258 85% 68%",
    "Cross-Platform": "340 75% 62%",
    "REST API": "258 85% 68%",
    "Responsive Design": "205 85% 60%",
    "DOM API": "258 85% 68%",
    "File System API": "258 85% 68%",
    "Web APIs": "258 85% 68%",
