    "Text-to-Speech": "205 85% 60%",
    "Audio Processing": "340 75% 62%",
    Libraries: "340 75% 62%",
    Middleware: "168 70% 52%",
    "Data Visualization": "205 85% 60%",
    Security: "0 72% 56%",
    "File Management": "258 85% 68%",
    Astro: "340 75% 62%",
    HTML5: "35 90% 62%",
    CSS3: "205 85% 60%",
    JavaScript: "205 85% 60%",
    pnpm: "258 85% 68%",
    "Game Development": "340 75% 62%",
    "3D Modeling": "35 90% 62%",
    Animations: "258 85% 68%",
