---
interface Props {
    className?: string;
}

const { className = "" } = Astro.props;
---

<a
    href="#inicio"
    class:list={["group flex items-center gap-2.5 no-underline", className]}
>
    <!-- Monogram mark -->
    <div class="relative w-9 h-9 flex items-center justify-center">
        <!-- Outer ring -->
        <div
            class="absolute inset-0 rounded-lg border border-[hsl(258_85%_68%/0.3)] group-hover:border-[hsl(258_85%_68%/0.5)] transition-colors duration-500"
            style="transform: rotate(3deg);"
        >
        </div>
        <!-- Inner filled square -->
        <div
            class="absolute inset-[3px] rounded-[5px] bg-[hsl(258_85%_68%/0.08)] group-hover:bg-[hsl(258_85%_68%/0.14)] transition-all duration-500"
        >
        </div>
        <!-- Letter -->
        <span
            class="relative text-base font-bold tracking-tight text-[hsl(258_85%_68%)] group-hover:text-[hsl(258_85%_75%)] transition-colors duration-300"
            style="font-family: 'Syne', system-ui, sans-serif; line-height: 1;"
        >
            A
        </span>
        <!-- Accent dot -->
        <div
            class="absolute -top-0.5 -right-0.5 w-[5px] h-[5px] rounded-full bg-[hsl(168_70%_52%)] opacity-80 group-hover:opacity-100 transition-opacity duration-300"
        >
        </div>
    </div>

    <!-- Wordmark -->
    <div
        class="flex items-baseline gap-0"
        style="font-family: 'Syne', system-ui, sans-serif;"
    >
        <span
            class="text-[1.05rem] font-medium tracking-tight text-[hsl(var(--color-foreground))] opacity-90 group-hover:opacity-100 transition-opacity duration-300"
        >
            angel
        </span>
        <span class="text-[1.05rem] font-bold tracking-tight gradient-text">
            ito
        </span>
    </div>
</a>
