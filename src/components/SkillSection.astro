---

<section
    id="habilidades"
    class="relative section-divider overflow-hidden"
    style={`padding-top: var(--section-gap); padding-bottom: var(--section-gap);`}
>
    <!-- Ambient orbs -->
    <div
        class="orb orb-primary w-[350px] h-[350px] top-1/4 -right-20 floating"
        style="animation-duration: 11s; animation-delay: -3s;"
        aria-hidden="true"
    >
    </div>
    <div
        class="orb orb-accent w-[300px] h-[300px] bottom-20 -left-20 floating"
        style="animation-duration: 14s; animation-delay: -7s;"
        aria-hidden="true"
    >
    </div>

    <div class="relative z-10 max-w-6xl mx-auto px-6">
        <!-- ═══ Section Header ═══ -->
        <div class="max-w-2xl mb-12 lg:mb-16">
            <!-- Section label -->
            <div class="flex items-center gap-3 mb-6 reveal">
                <div class="w-8 h-px bg-[hsl(258_85%_68%/0.5)]"></div>
                <span
                    class="text-[0.6875rem] font-semibold uppercase tracking-[0.2em] text-[hsl(258_85%_68%)]"
                    style="font-family: 'Outfit', system-ui, sans-serif;"
                >
                    {t("skills.title")}
                </span>
            </div>

            <!-- Title -->
            <h2
                class="text-[clamp(2rem,4.5vw,3.5rem)] font-bold leading-[1.05] tracking-tight text-[hsl(var(--color-foreground))] mb-5 reveal"
                style="font-family: 'Syne', system-ui, sans-serif; transition-delay: 80ms;"
            >
                {
                    lang === "en" ? (
                        <>
                            Tools &{" "}
                            <span class="gradient-text">technologies</span>
                        </>
                    ) : lang === "fr" ? (
                        <>
                            Outils &{" "}
                            <span class="gradient-text">technologies</span>
                        </>
                    ) : (
                        <>
                            Herramientas y{" "}
                            <span class="gradient-text">tecnologías</span>
                        </>
                    )
                }
            </h2>

            <p
                class="text-base md:text-lg leading-relaxed text-[hsl(var(--color-muted-foreground))] text-pretty reveal"
                style="transition-delay: 160ms;"
            >
                {t("skills.subtitle")}
            </p>
        </div>

        <!-- ═══ Category Legend ═══ -->
        <div
            class="flex flex-wrap items-center gap-5 mb-10 lg:mb-14 reveal"
            style="transition-delay: 200ms;"
        >
            {
                categories.map((cat) => (
                    <div class="flex items-center gap-2.5">
                        <div
                            class="w-2 h-2 rounded-full"
                            style={`background: hsl(${cat.color});`}
                        />
                        <span
                            class="text-xs font-medium text-[hsl(var(--color-muted-foreground))]"
                            style="font-family: 'Outfit', system-ui, sans-serif;"
                        >
                            {cat.label}
                        </span>
                    </div>
                ))
            }
        </div>
    </div>

    <!-- ═══ Marquee Rows — Full bleed ═══ -->
    <div class="flex flex-col gap-4 reveal" style="transition-delay: 250ms;">
        {
            skillRows.map((row) => (
                <div class="marquee-container">
                    <div
                        class={
                            row.direction === "reverse"
                                ? "marquee-track-reverse"
                                : "marquee-track"
                        }
                        style={`animation-duration: ${row.speed};`}
                    >
                        {/* Duplicate skills array for seamless loop */}
                        {[...row.skills, ...row.skills].map((skill) => (
                            <div
                                class="group/skill shrink-0 flex items-center gap-3 px-5 py-3 rounded-xl border transition-all duration-300 cursor-default select-none hover:scale-[1.03]"
                                style={`
                                    background: hsl(${skill.color} / 0.04);
                                    border-color: hsl(${skill.color} / 0.08);
                                `}
                            >
                                {/* Color dot */}
                                <div
                                    class="w-1.5 h-1.5 rounded-full shrink-0 transition-transform duration-300 group-hover/skill:scale-150"
                                    style={`background: hsl(${skill.color});`}
                                />

                                {/* Skill name */}
                                <span
                                    class="text-sm font-medium whitespace-nowrap transition-colors duration-300"
                                    style={`
                                        color: hsl(${skill.color} / 0.75);
                                        font-family: 'JetBrains Mono', monospace;
                                        letter-spacing: 0.01em;
                                    `}
                                >
                                    {skill.name}
                                </span>
                            </div>
                        ))}
                    </div>
                </div>
            ))
        }
    </div>

    <!-- ═══ Bottom decorative element ═══ -->
    <div class="max-w-6xl mx-auto px-6">
        <div
            class="mt-16 lg:mt-24 reveal flex items-center gap-4"
            style="transition-delay: 100ms;"
        >
            <div
                class="flex-1 h-px bg-linear-to-r from-[hsl(225_10%_16%)] to-transparent"
            >
            </div>
            <div class="flex gap-1.5" aria-hidden="true">
                <div class="w-1 h-1 rounded-full bg-[hsl(168_70%_52%/0.4)]">
                </div>
                <div class="w-1 h-1 rounded-full bg-[hsl(168_70%_52%/0.25)]">
                </div>
                <div class="w-1 h-1 rounded-full bg-[hsl(168_70%_52%/0.12)]">
                </div>
            </div>
            <div
                class="flex-1 h-px bg-linear-to-l from-[hsl(225_10%_16%)] to-transparent"
            >
            </div>
        </div>
    </div>
</section>
