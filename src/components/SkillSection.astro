            { name: "Node.js", color: "168 70% 52%" },
            { name: "Telegram Bot API", color: "205 85% 60%" },
            { name: "REST APIs", color: "258 85% 68%" },
            { name: "Express.js", color: "168 70% 52%" },
            { name: "Async Programming", color: "168 70% 52%" },
