---
import Layout from "@/layouts/main.astro";
import { getLangFromUrl, useTranslations } from "@/i18n/utils";
import Logo from "@/components/Logo.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout
    title={`${t("404.title")} — Angel Portuondo`}
    description={t("404.description")}
    noindex={true}
>
    <div
        class="min-h-dvh relative flex flex-col items-center justify-center overflow-hidden"
    >
        <!-- ═══ Ambient Orbs ═══ -->
        <div
            class="orb orb-primary w-[450px] h-[450px] top-1/4 -right-32 floating"
            style="animation-duration: 10s;"
            aria-hidden="true"
        >
        </div>
        <div
            class="orb orb-accent w-[350px] h-[350px] bottom-1/4 -left-24 floating"
            style="animation-duration: 13s; animation-delay: -4s;"
            aria-hidden="true"
        >
        </div>
        <div
            class="orb orb-warm w-[200px] h-[200px] top-1/3 left-1/3 floating"
            style="animation-duration: 16s; animation-delay: -8s;"
            aria-hidden="true"
        >
        </div>

        <!-- ═══ Grid Lines (decorative) ═══ -->
        <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
            <div
                class="absolute top-0 bottom-0 left-[15%] w-px bg-linear-to-b from-transparent via-[hsl(225_10%_16%/0.3)] to-transparent"
            >
            </div>
            <div
                class="absolute top-0 bottom-0 right-[15%] w-px bg-linear-to-b from-transparent via-[hsl(225_10%_16%/0.2)] to-transparent"
            >
            </div>
            <div
                class="absolute left-0 right-0 top-[40%] h-px bg-linear-to-r from-transparent via-[hsl(225_10%_16%/0.25)] to-transparent"
            >
            </div>
            <div
                class="absolute left-0 right-0 bottom-[35%] h-px bg-linear-to-r from-transparent via-[hsl(225_10%_16%/0.15)] to-transparent"
            >
            </div>
        </div>

        <!-- ═══ Content ═══ -->
        <div class="relative z-10 text-center px-6 max-w-2xl mx-auto">
            <!-- Logo at top -->
            <div class="mb-16 flex justify-center hero-text-reveal">
                <div style="--delay: 0ms;">
                    <Logo />
                </div>
            </div>

            <!-- Giant 404 number -->
            <div class="hero-text-reveal mb-4">
                <div class="relative inline-block" style="--delay: 150ms;">
                    <!-- Shadow number behind -->
                    <span
                        class="absolute top-1 left-1 text-[clamp(8rem,20vw,14rem)] font-extrabold leading-none select-none text-[hsl(225_10%_8%)]"
                        style="font-family: 'Syne', system-ui, sans-serif; letter-spacing: -0.06em;"
                        aria-hidden="true"
                    >
                        404
                    </span>
                    <!-- Main number with gradient -->
                    <span
                        class="relative gradient-text text-[clamp(8rem,20vw,14rem)] font-extrabold leading-none select-none"
                        style="font-family: 'Syne', system-ui, sans-serif; letter-spacing: -0.06em;"
                    >
                        404
                    </span>
                </div>
            </div>

            <!-- Decorative dot cluster -->
            <div
                class="flex items-center justify-center gap-2 mb-8 hero-text-reveal"
            >
                <div style="--delay: 300ms;" class="flex items-center gap-2">
                    <div
                        class="w-1.5 h-1.5 rounded-full bg-[hsl(258_85%_68%/0.5)]"
                    >
                    </div>
                    <div class="w-8 h-px bg-[hsl(258_85%_68%/0.3)]"></div>
                    <div
                        class="w-1.5 h-1.5 rounded-full bg-[hsl(258_85%_68%/0.3)]"
                    >
                    </div>
                    <div class="w-8 h-px bg-[hsl(258_85%_68%/0.3)]"></div>
                    <div
                        class="w-1.5 h-1.5 rounded-full bg-[hsl(258_85%_68%/0.15)]"
                    >
                    </div>
                </div>
            </div>

            <!-- Title -->
            <div class="hero-text-reveal mb-5">
                <h1
                    class="text-[clamp(1.5rem,3.5vw,2.25rem)] font-bold leading-tight tracking-tight text-[hsl(var(--color-foreground))]"
                    style="font-family: 'Syne', system-ui, sans-serif; --delay: 400ms;"
                >
                    {t("404.title")}
                </h1>
            </div>

            <!-- Description -->
            <div class="hero-text-reveal mb-12">
                <p
                    class="text-base md:text-lg leading-relaxed text-[hsl(var(--color-muted-foreground)/0.7)] max-w-md mx-auto text-pretty"
                    style="--delay: 520ms;"
                >
                    {t("404.description")}
                </p>
            </div>

            <!-- CTA Button -->
            <div class="hero-text-reveal">
                <div style="--delay: 660ms;">
                    <a
                        href={lang === "es" ? "/" : `/${lang}/`}
                        class="group relative inline-flex items-center gap-2.5 px-7 py-3.5 rounded-full text-sm font-semibold text-[hsl(var(--color-primary-foreground))] overflow-hidden transition-all duration-500 hover:shadow-[0_0_40px_hsl(258_85%_68%/0.25)]"
                        style="font-family: 'Outfit', system-ui, sans-serif;"
                    >
                        <!-- Gradient background -->
                        <div
                            class="absolute inset-0 bg-linear-to-r from-[hsl(258_85%_68%)] to-[hsl(290_70%_60%)] transition-opacity duration-300"
                        >
                        </div>
                        <div
                            class="absolute inset-0 bg-linear-to-r from-[hsl(290_70%_60%)] to-[hsl(340_75%_62%)] opacity-0 group-hover:opacity-100 transition-opacity duration-500"
                        >
                        </div>

                        <!-- Arrow pointing left -->
                        <svg
                            class="relative z-10 w-4 h-4 transition-transform duration-300 group-hover:-translate-x-0.5"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2.5"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                        >
                            <line x1="19" y1="12" x2="5" y2="12"></line>
                            <polyline points="12 19 5 12 12 5"></polyline>
                        </svg>

                        <span class="relative z-10">
                            {t("404.back")}
                        </span>
                    </a>
                </div>
            </div>

            <!-- Error code label (translated) -->
            <div class="hero-text-reveal mt-16">
                <div
                    style="--delay: 800ms;"
                    class="inline-flex items-center gap-2.5 px-3.5 py-1.5 rounded-full border border-[hsl(225_10%_16%/0.5)] bg-[hsl(225_12%_9%/0.4)]"
                >
                    <span
                        class="w-1.5 h-1.5 rounded-full bg-[hsl(340_75%_55%/0.6)]"
                    >
                    </span>
                    <span
                        class="text-[0.625rem] font-medium tracking-[0.15em] uppercase text-[hsl(var(--color-muted-foreground)/0.4)]"
                        style="font-family: 'JetBrains Mono', monospace;"
                    >
                        {t("404.label")}
                    </span>
                </div>
            </div>
        </div>

        <!-- ═══ Decorative Corner Elements ═══ -->
        <div
            class="absolute bottom-8 left-8 hidden md:block"
            aria-hidden="true"
        >
            <div class="flex flex-col gap-1 items-start">
                <div class="w-6 h-px bg-[hsl(225_10%_16%/0.4)]"></div>
                <div class="w-3 h-px bg-[hsl(225_10%_16%/0.25)]"></div>
            </div>
        </div>
        <div
            class="absolute bottom-8 right-8 hidden md:block"
            aria-hidden="true"
        >
            <div class="flex flex-col gap-1 items-end">
                <div class="w-6 h-px bg-[hsl(225_10%_16%/0.4)]"></div>
                <div class="w-3 h-px bg-[hsl(225_10%_16%/0.25)]"></div>
            </div>
        </div>
        <div class="absolute top-8 right-8 hidden md:block" aria-hidden="true">
            <div
                class="w-4 h-4 border border-[hsl(258_85%_68%/0.1)] rounded-sm transform rotate-45"
            >
            </div>
        </div>
    </div>
</Layout>
